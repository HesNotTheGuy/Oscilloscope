{
  "name": "dso1-oscilloscope",
  "version": "1.1.0",
  "description": "DSO-1 Oscilloscope — real-time audio visualization",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "screenshots": "electron screenshot.js",
    "dist": "electron-builder --win",
    "dist:installer": "electron-builder --win nsis --x64",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.dso1.oscilloscope",
    "productName": "DSO-1 Oscilloscope",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "dist",
      "buildResources": "build-assets"
    },
    "files": [
      "index.html",
      "display.html",
      "style.css",
      "app.js",
      "src/**/*",
      "main.js",
      "preload.js",
      "preload-display.js",
      "logo.svg",
      "icon.ico",
      "icon.png"
    ],
    "icon": "icon.ico",
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DSO-1 Oscilloscope",
      "installerHeader": "",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
